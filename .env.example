# Configurazione consigliata per MindLog in produzione.
# Assetto consigliato finale: Postgres via Vercel Marketplace (Neon o Supabase) con DATABASE_URL.
# Se DATABASE_URL manca, l'app usa il fallback remoto cifrato su GitHub.

DATABASE_URL=

GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_REPO=baiaelmillantater/mindlog
GITHUB_STORAGE_BRANCH=mindlog-data
GITHUB_STORAGE_PATH=secure/mindlog-db.enc
MINDLOG_SECRET_KEY=
MINDLOG_SESSION_SECRET=
MINDLOG_ADMIN_USERNAME=martina
MINDLOG_ADMIN_PASSWORD=1234

# Regola suggerita per i nomi utente paziente:
# 3-30 caratteri, solo lettere minuscole, numeri, punto, trattino o underscore.
